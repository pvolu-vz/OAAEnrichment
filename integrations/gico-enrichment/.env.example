# ─────────────────────────────────────────────────────────────────────────────
# GICO Email Enrichment — Environment Variable Template
# Copy this file to .env and fill in your values before running the script.
# chmod 600 .env  ← recommended once filled in
# ─────────────────────────────────────────────────────────────────────────────

# Veza tenant hostname (no https:// prefix, no trailing slash)
# Example: acme.veza.com
VEZA_URL=your-tenant.veza.com

# Veza API key with OAA read/write permissions
VEZA_API_KEY=your_veza_api_key_here

# Optional: override the email domain suffix (default: @smurfitwestrock.com)
# EMAIL_DOMAIN=@smurfitwestrock.com
